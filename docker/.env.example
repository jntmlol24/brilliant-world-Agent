# 应用配置
DEBUG=False
HOST=0.0.0.0
PORT=8000

# LLM 配置（阿里云 DashScope OpenAI 兼容接口 / Qwen-Plus）
LLM_API_KEY=your_dashscope_api_key
LLM_MODEL=qwen-plus-2025-07-28
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Qwen 配置（备选，原生 DashScope 接入）
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=qwen-14b-chat

# 嵌入模型 API 配置（阿里云百炼 text-embedding-v3 / DashScope OpenAI 兼容接口）
EMBEDDING_MODEL_NAME=text-embedding-v3
EMBEDDING_API_KEY=your_dashscope_api_key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=32

# Milvus 配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=bw-user
MILVUS_PASSWORD=bw-pw
MILVUS_DB_NAME=bw_Agent_db

# PostgreSQL 配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=brillian_world_agent

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=2
REDIS_PASSWORD=aa123123

# Celery 配置
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 业务阈值
USER_STYLE_MIN_COUNT=50
STYLE_SIMILARITY_THRESHOLD=0.6
BEHAVIOR_VIEW_THRESHOLD=10
BEHAVIOR_DURATION_THRESHOLD=60
