# Tavily API 配置
TAVILY_API_KEY=

# 服务监听地址（Swagger 文档端口）
HOST=0.0.0.0
PORT=38000

# 大语言模型 API 配置（当前使用：阿里云 DashScope OpenAI 兼容接口 / Qwen-Plus）
LLM_API_KEY=
LLM_MODEL=qwen-plus-2025-07-28
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 嵌入式模型 API 配置（当前使用：阿里云百炼 text-embedding-v3 / DashScope OpenAI 兼容接口）
EMBEDDING_MODEL_NAME=text-embedding-v3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=32

# PostgreSQL / pgVector 配置（端口 5433）
POSTGRES_HOST=localhost
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Milvus 配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DB_NAME=
